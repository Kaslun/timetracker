{
  "name": "attensi-time-tracker",
  "version": "0.1.4",
  "description": "Attensi Time Tracker — a calm Windows desktop time tracker",
  "main": "out/main/index.js",
  "author": {
    "name": "Attensi"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kaslun/timetracker.git"
  },
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\" \"tests/**/*.{ts,tsx}\" \"docs/**/*.md\" \"*.{json,md,cjs,ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html}\" \"tests/**/*.{ts,tsx}\" \"docs/**/*.md\" \"*.{json,md,cjs,ts,js}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check": "npm run typecheck && npm run lint && npm run test",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps && (husky || true)",
    "dist:win": "electron-vite build && electron-builder --win nsis portable",
    "dist:win:portable": "electron-vite build && electron-builder --win portable",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "framer-motion": "^12.38.0",
    "keytar": "^7.9.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.6",
    "lint-staged": "^16.4.0",
    "playwright": "^1.48.0",
    "prettier": "^3.3.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
